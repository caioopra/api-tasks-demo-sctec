# Porta HTTP em que a API escuta (inteiro positivo). Default: 3000
PORT=3000

# Ambiente de execução. Valores aceitos: development | test | production
NODE_ENV=development

# Segredo usado para assinar os tokens (fake-JWT) emitidos por auth.service.
# Mínimo 16 caracteres. Tem default só para a demo — sobrescreva em qualquer
# ambiente real.
JWT_SECRET=insecure-dev-secret-please-override
